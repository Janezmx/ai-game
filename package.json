{
  "name": "aigame-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "shared",
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev:frontend": "npm run start --workspace=@aigame/frontend",
    "dev:backend": "npm run dev --workspace=@aigame/backend",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "typecheck": "npm run typecheck --workspace=@aigame/shared"
  },
  "devDependencies": {
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.0.0",
    "typescript": "^5.4.0"
  }
}
